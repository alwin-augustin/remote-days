{
  "name": "@remotedays/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "clean": "rimraf dist",
    "lint": "eslint 'src/**/*.{js,ts}'",
    "format": "prettier --write 'src/**/*.{js,ts}'",
    "build": "tsup src/server.ts --format cjs --out-dir dist --clean --no-splitting",
    "start": "node -r dotenv/config dist/server.js dotenv_config_path=../../.env",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:seed": "ts-node -r dotenv/config src/scripts/seed.ts dotenv_config_path=../../.env",
    "db:seed:zones": "ts-node -r dotenv/config src/scripts/seed-compliance-zones.ts dotenv_config_path=../../.env",
    "db:seed:demo": "ts-node -r dotenv/config src/scripts/seed-demo.ts dotenv_config_path=../../.env"
  },
  "dependencies": {
    "@fastify/cookie": "^8.3.0",
    "@fastify/cors": "^8.3.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/postgres": "^5.2.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^2.1.0",
    "bcrypt": "^5.1.0",
    "csv-parse": "^6.1.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "fastify": "^4.21.0",
    "jsonwebtoken": "^9.0.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^7.0.11",
    "pg": "^8.11.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@remotedays/types": "*",
    "@testcontainers/postgresql": "^11.9.0",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.4.5",
    "@types/node-cron": "^3.0.8",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.10.2",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/coverage-v8": "^4.0.14",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.7.4",
    "testcontainers": "^11.9.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.14"
  }
}

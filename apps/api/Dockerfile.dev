FROM node:22-alpine

WORKDIR /app

# Copy root package config to install workspace dependencies
COPY package.json .
COPY apps/api/package.json ./apps/api/
COPY packages/types/package.json ./packages/types/

# Install dependencies
RUN npm install

# The rest of the code is mounted via docker-compose volume
# We just define the start command
CMD ["npm", "run", "dev", "--workspace=apps/api"]